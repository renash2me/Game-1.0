[gd_scene load_steps=2 format=3 uid="uid://aethermoor_char_select"]

[ext_resource type="Script" path="res://scripts/ui/character_select.gd" id="1_charselect"]

[node name="CharacterSelect" type="Control"]
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_charselect")

[node name="VBox" type="VBoxContainer" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 20.0
offset_top = 20.0
offset_right = -20.0
offset_bottom = -20.0

[node name="Title" type="Label" parent="VBox"]
text = "Selecionar Personagem"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 24

[node name="Scroll" type="ScrollContainer" parent="VBox"]
size_flags_vertical = 3

[node name="Grid" type="GridContainer" parent="VBox/Scroll"]
columns = 3
theme_override_constants/h_separation = 10
theme_override_constants/v_separation = 10

[node name="BtnRow" type="HBoxContainer" parent="VBox"]

[node name="BtnVoltar" type="Button" parent="VBox/BtnRow"]
text = "< Voltar"

[node name="Spacer" type="Control" parent="VBox/BtnRow"]
size_flags_horizontal = 3

[node name="BtnCriar" type="Button" parent="VBox/BtnRow"]
text = "Novo personagem"

[node name="CreatePanel" type="Panel" parent="."]
anchor_left = 0.3
anchor_top = 0.2
anchor_right = 0.7
anchor_bottom = 0.8
visible = false

[node name="VBox" type="VBoxContainer" parent="CreatePanel"]
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 20.0
offset_top = 20.0
offset_right = -20.0
offset_bottom = -20.0

[node name="Title" type="Label" parent="CreatePanel/VBox"]
text = "Novo Personagem (Novice)"
horizontal_alignment = 1

[node name="Name" type="LineEdit" parent="CreatePanel/VBox"]
placeholder_text = "Nome do personagem"
custom_minimum_size = Vector2(0, 36)

[node name="Error" type="Label" parent="CreatePanel/VBox"]
text = ""
modulate = Color(1, 0.3, 0.3, 1)

[node name="BtnRow" type="HBoxContainer" parent="CreatePanel/VBox"]

[node name="BtnCancelar" type="Button" parent="CreatePanel/VBox/BtnRow"]
text = "Cancelar"

[node name="Spacer" type="Control" parent="CreatePanel/VBox/BtnRow"]
size_flags_horizontal = 3

[node name="BtnConfirmar" type="Button" parent="CreatePanel/VBox/BtnRow"]
text = "Criar"

[connection signal="pressed" from="VBox/BtnRow/BtnVoltar" to="." method="_on_back_pressed"]
[connection signal="pressed" from="VBox/BtnRow/BtnCriar" to="." method="_on_create_pressed"]
[connection signal="pressed" from="CreatePanel/VBox/BtnRow/BtnCancelar" to="." method="_on_cancel_create_pressed"]
[connection signal="pressed" from="CreatePanel/VBox/BtnRow/BtnConfirmar" to="." method="_on_confirm_create_pressed"]
