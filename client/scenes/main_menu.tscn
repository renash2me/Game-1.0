[node name="Title" type="Label" parent="Center/VBox"]
text = "Aethermoor"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 32

[node name="Spacer" type="Control" parent="Center/VBox"]
custom_minimum_size = Vector2(0, 20)

[node name="Tabs" type="TabContainer" parent="Center/VBox"]
custom_minimum_size = Vector2(360, 220)

[node name="Login" type="VBoxContainer" parent="Center/VBox/Tabs"]
metadata/_tab_name = "Login"

[node name="Username" type="LineEdit" parent="Center/VBox/Tabs/Login"]
placeholder_text = "Usuário"
custom_minimum_size = Vector2(320, 36)

[node name="Password" type="LineEdit" parent="Center/VBox/Tabs/Login"]
placeholder_text = "Senha"
secret = true
